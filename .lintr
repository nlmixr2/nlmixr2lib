linters: linters_with_defaults(
    object_name_linter   = NULL,
    object_length_linter = NULL,
    object_usage_linter  = NULL,
    line_length_linter   = line_length_linter(120L),
    indentation_linter   = NULL,
    pipe_consistency_linter = NULL
  )
exclusions: list(
    "inst/modeldb",
    "data-raw",
    "data",
    "docs",
    "src",
    # Vignettes typically contain long lines in URLs, equation comments,
    # and prose; the long-line linter adds noise with no impact on
    # package code quality. Keep other linters active on vignettes by
    # exempting only line_length_linter here.
    list("vignettes", linters = "line_length_linter")
  )
encoding: "UTF-8"
